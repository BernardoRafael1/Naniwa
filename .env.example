# Supabase Auth (autenticação principal do app)
VITE_SUPABASE_URL="your-supabase-url"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# MangaDex API
# Local/Tauri (desktop): chama a MangaDex diretamente.
VITE_MANGADEX_API_BASE_URL="https://api.mangadex.org"
# Na Vercel (web), defina como o proxy para evitar CORS:
# VITE_MANGADEX_API_BASE_URL="/api/mangadex"

# Proxy de capas (evita o placeholder da MangaDex na web).
# Local/Tauri: vazio (carrega direto do CDN).
VITE_MANGADEX_COVER_PROXY_BASE_URL=""
# Na Vercel, usar:
# VITE_MANGADEX_COVER_PROXY_BASE_URL="/api/mangadex-cover"

# Proxy das páginas dos capítulos (evita imagens quebradas no leitor web).
# Local/Tauri: vazio (carrega direto da MangaDex).
VITE_MANGADEX_PAGE_PROXY_BASE_URL=""
# Na Vercel, usar:
# VITE_MANGADEX_PAGE_PROXY_BASE_URL="/api/mangadex-page"

# Servidor local legado (Express + Prisma) — mantido temporariamente, não usado na autenticação
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/naniwa_dev?schema=public"
JWT_SECRET="change-me"
SERVER_PORT=3333
